          "branch_provider": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "twilight:twilight_mangrove_wood",
              "Properties": {
                "axis": "y"
              }
            }
          },
          "count_minimum": 0,
          "downwards_pitch": 0.25,
          "length": 6.0,
          "random_add_count": 3,
          "random_add_length": 2.0,
          "spacing_yaw": 0.3
