{
  "type": "minecraft:tree",
  "config": {
    "below_trunk_provider": {
      "type": "minecraft:rule_based_state_provider",
      "rules": [
        {
          "if_true": {
            "type": "minecraft:not",
            "predicate": {
              "type": "minecraft:matching_block_tag",
              "tag": "minecraft:cannot_replace_below_tree_trunk"
            }
          },
          "then": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "minecraft:dirt"
            }
          }
        }
      ]
    },
    "decorators": [
      {
        "type": "minecraft:tree_roots_decorator",
        "additional_random_strands": 1,
        "base_strand_count": 3,
        "exposed_roots_provider": {
          "type": "minecraft:simple_state_provider",
          "state": {
            "Name": "twilight:twilight_mangrove_root"
          }
        },
        "ground_roots_provider": {
          "type": "minecraft:weighted_state_provider",
          "entries": [
            {
              "data": {
                "Name": "twilight:root_block"
              },
              "weight": 4
            },
            {
              "data": {
                "Name": "twilight:liveroot_block"
              },
              "weight": 1
            }
          ]
        },
        "rootPenetrability": 1,
        "root_length": 12,
