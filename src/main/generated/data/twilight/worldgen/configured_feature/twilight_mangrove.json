      "offset": 0,
      "random_add_horizontal": 2,
      "random_add_vertical": 0,
      "shag_factor": 15,
      "vertical_filler_bias": -0.25,
      "vertical_radius": 1.5
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "twilight:twilight_mangrove_leaves",
        "Properties": {
          "distance": "7",
          "persistent": "false",
          "waterlogged": "false"
        }
      }
    },
    "ignore_vines": false,
    "minimum_size": {
      "type": "minecraft:two_layers_feature_size",
      "limit": 4,
      "lower_size": 1,
      "upper_size": 1
